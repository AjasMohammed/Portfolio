# GitHub personal access token used to fetch public profile data and the
# contributions calendar via GitHub's GraphQL API.
#
# Without this token:
#   - REST calls (repos, user) still work but are subject to the strict 60
#     req/hr unauthenticated rate limit.
#   - The contributions heatmap (GraphQL) will not load — GraphQL requires auth.
#
# Create one at: https://github.com/settings/tokens
#   - Classic tokens: scope `read:user` (and `repo` only if you also want to
#     surface private contributions).
#   - Fine-grained: read-only access to your own account is enough.
#
# Copy this file to `.env.local` and fill in the value.
PORTFOLIO_GITHUB_TOKEN=

# Public site origin (no trailing slash). Used as metadataBase for OG/Twitter
# absolute URLs, plus the sitemap and robots host. Set this in your hosting
# provider for production (e.g. https://ajasmohammed.com).
NEXT_PUBLIC_SITE_URL=

# ───────────────────────────────────────────────────────────────────────────
# Testimonials ("kind words" card)
#
# Submissions are POSTed by the site to a Google Form (no third-party deps).
# Approved entries are read back from the Form's linked Google Sheet as CSV.
#
# Setup (one-time, in Google):
#   1. Create a Google Form with these fields, in this order — labels can be
#      anything readable:
#        - "Name"          (short answer, required)
#        - "You are my…"   (short answer, required — free text like mentor,
#                           teammate, colleague, friend, client, etc.)
#        - "Message"       (paragraph, required)
#        - "Email"         (short answer, optional)
#   2. Form → Responses tab → "Link to Sheets" → create a new sheet.
#   3. In that sheet, add a column titled "Approved" at the end. Type TRUE
#      (or yes / 1) for each row you want to publish on the site.
#   4. In the sheet: File → Share → Publish to web → pick the response tab
#      and "Comma-separated values (.csv)". Copy the URL into
#      TESTIMONIALS_SHEET_CSV_URL below.
#   5. In the Form: ⋮ menu → "Get email notifications for new responses".
#      Submissions will email the form owner immediately.
#   6. Find the form's POST endpoint + per-question entry IDs:
#        - Form's action URL is:
#          https://docs.google.com/forms/u/0/d/e/<FORM_ID>/formResponse
#        - To get each entry id, use ⋮ menu → "Get pre-filled link", fill
#          every field with placeholder text, then "Get link". The resulting
#          URL contains entry.123456789=PLACE for every field — those
#          numeric ids are what go into the entry vars below.
TESTIMONIALS_FORM_ACTION_URL=
TESTIMONIALS_ENTRY_NAME=
TESTIMONIALS_ENTRY_ROLE=
TESTIMONIALS_ENTRY_MESSAGE=
TESTIMONIALS_ENTRY_EMAIL=
TESTIMONIALS_SHEET_CSV_URL=

# Shared secret for GET/POST /api/testimonials/revalidate — busts the cached
# testimonials after you approve a row in the sheet. The endpoint refuses all
# requests (503) until this is set; send it as an `x-revalidate-secret` header:
#   curl -H "x-revalidate-secret: $SECRET" https://<site>/api/testimonials/revalidate
# Generate one with: openssl rand -hex 32
TESTIMONIALS_REVALIDATE_SECRET=

# Visits are counted in Upstash Redis (KV_REST_API_URL/TOKEN or
# UPSTASH_REDIS_REST_URL/TOKEN). Local dev reads the counter but never
# increments it, so dev sessions don't inflate production numbers.
# Set to 1 to test the write path from a dev server.
VISITS_LOG_IN_DEV=
